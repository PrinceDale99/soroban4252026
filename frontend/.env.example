VITE_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── Black Belt Feature: Fee Sponsorship (Gasless Transactions) ────────────────
# When set, all scholar gas fees are paid by the sponsor via FeeBumpTransaction.
# Scholars need ZERO XLM to claim their stipends.
#
# To set up a sponsor account on testnet:
#   stellar keys generate sponsor --network testnet
#   stellar keys fund sponsor --network testnet          # Friendbot funds it
#   stellar keys show sponsor                            # Copy the secret here
#
# ⚠️  SECURITY WARNING:
#   - NEVER commit a real mainnet secret key to version control.
#   - For production, this should be handled by a backend signing service.
#   - On testnet, client-side signing is acceptable for demonstration.
#
VITE_SPONSOR_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
